generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChapterGenerationState {
  planned
  drafted
  reviewed
  repaired
  approved
  published
}

enum PipelineJobStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

enum BeatStatus {
  planned
  completed
  skipped
}

enum FactCategory {
  world
  character
  timeline
  plot
  rule
}

enum RagOwnerType {
  novel
  chapter
  world
  character
  bible
  chapter_summary
  consistency_fact
  character_timeline
  world_library_item
  knowledge_document
  chat_message
}

enum RagJobType {
  upsert
  delete
  rebuild
}

enum RagJobStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

enum KnowledgeDocumentStatus {
  enabled
  disabled
  archived
}

enum KnowledgeIndexStatus {
  idle
  queued
  running
  succeeded
  failed
}

enum KnowledgeBindingTargetType {
  novel
  world
}

enum BookAnalysisStatus {
  draft
  queued
  running
  succeeded
  failed
  cancelled
  archived
}

enum BookAnalysisSectionStatus {
  idle
  running
  succeeded
  failed
}

enum ImageSceneType {
  character
  novel_cover
  chapter_illustration
}

enum ProjectMode {
  ai_led
  co_pilot
  draft_mode
  auto_pipeline
}

enum NarrativePov {
  first_person
  third_person
  mixed
}

enum PacePreference {
  slow
  balanced
  fast
}

enum EmotionIntensity {
  low
  medium
  high
}

enum AIFreedom {
  low
  medium
  high
}

enum ProjectProgressStatus {
  not_started
  in_progress
  completed
  rework
  blocked
}

enum StorylineVersionStatus {
  draft
  active
  frozen
}

enum VolumePlanVersionStatus {
  draft
  active
  frozen
}

enum ChapterStatus {
  unplanned
  pending_generation
  generating
  pending_review
  needs_repair
  completed
}

enum PipelineRunMode {
  fast
  polish
}

enum PipelineRepairMode {
  detect_only
  light_repair
  heavy_repair
  continuity_only
  character_only
  ending_only
}

enum AgentRunStatus {
  queued
  running
  waiting_approval
  succeeded
  failed
  cancelled
}

enum NovelWorkflowLane {
  manual_create
  auto_director
}

enum NovelWorkflowTaskStatus {
  queued
  running
  waiting_approval
  succeeded
  failed
  cancelled
}

enum AgentStepType {
  planning
  tool_call
  tool_result
  reasoning
  write
  approval
  answer
}

enum AgentStepStatus {
  pending
  running
  succeeded
  failed
  cancelled
}

enum AgentApprovalStatus {
  pending
  approved
  rejected
  expired
}

enum CreativeHubThreadStatus {
  idle
  busy
  interrupted
  error
}

enum StoryPlanLevel {
  book
  arc
  chapter
}

enum StoryPlanRole {
  setup
  progress
  pressure
  turn
  payoff
  cooldown
}

enum AuditType {
  continuity
  character
  plot
  mode_fit
}

enum AuditIssueStatus {
  open
  resolved
  ignored
}

enum PayoffLedgerScopeType {
  book
  volume
  chapter
}

enum PayoffLedgerStatus {
  setup
  hinted
  pending_payoff
  paid_off
  failed
  overdue
}

enum StyleBindingTargetType {
  novel
  chapter
  task
}

enum AntiAiRuleType {
  forbidden
  risk
  encourage
}

enum AntiAiSeverity {
  low
  medium
  high
}

enum CharacterGender {
  male
  female
  other
  unknown
}

model Novel {
  id                String      @id @default(cuid())
  title             String
  description       String?
  targetAudience    String?
  bookSellingPoint  String?
  competingFeel     String?
  first30ChapterPromise String?
  commercialTagsJson String?
  status            String      @default("draft")
  writingMode       String      @default("original")
  projectMode       ProjectMode?
  narrativePov      NarrativePov?
  pacePreference    PacePreference?
  styleTone         String?
  emotionIntensity  EmotionIntensity?
  aiFreedom         AIFreedom?
  postGenerationStyleReviewEnabled Boolean @default(true)
  defaultChapterLength Int?
  estimatedChapterCount Int?
  projectStatus     ProjectProgressStatus? @default(not_started)
  storylineStatus   ProjectProgressStatus? @default(not_started)
  outlineStatus     ProjectProgressStatus? @default(not_started)
  resourceReadyScore Int?
  sourceNovelId     String?
  sourceKnowledgeDocumentId String?
  continuationBookAnalysisId String?
  continuationBookAnalysisSections String?
  outline           String?
  structuredOutline String?
  storyWorldSliceJson String?
  storyWorldSliceOverridesJson String?
  storyWorldSliceSchemaVersion Int @default(1)
  genreId           String?
  primaryStoryModeId String?
  secondaryStoryModeId String?
  worldId           String?
  genre             NovelGenre? @relation(fields: [genreId], references: [id])
  primaryStoryMode  NovelStoryMode? @relation("NovelPrimaryStoryMode", fields: [primaryStoryModeId], references: [id], onDelete: SetNull)
  secondaryStoryMode NovelStoryMode? @relation("NovelSecondaryStoryMode", fields: [secondaryStoryModeId], references: [id], onDelete: SetNull)
  world             World?      @relation(fields: [worldId], references: [id], onDelete: SetNull)
  sourceNovel       Novel?      @relation("NovelContinuation", fields: [sourceNovelId], references: [id], onDelete: SetNull)
  continuationNovels Novel[]    @relation("NovelContinuation")
  sourceKnowledgeDocument KnowledgeDocument? @relation("NovelKnowledgeContinuation", fields: [sourceKnowledgeDocumentId], references: [id], onDelete: SetNull)
  continuationBookAnalysis BookAnalysis? @relation("NovelContinuationBookAnalysis", fields: [continuationBookAnalysisId], references: [id], onDelete: SetNull)
  chapters          Chapter[]
  characters        Character[]
  characterLibraryLinks CharacterLibraryLink[]
  characterSyncProposals CharacterSyncProposal[]
  characterRelations CharacterRelation[]
  characterCastOptions CharacterCastOption[]
  characterTimelines CharacterTimeline[]
  characterCandidates CharacterCandidate[]
  characterVolumeAssignments CharacterVolumeAssignment[]
  characterFactionTracks CharacterFactionTrack[]
  characterRelationStages CharacterRelationStage[]
  characterResourceItems CharacterResourceLedgerItem[]
  characterResourceEvents CharacterResourceEvent[]
  bible             NovelBible?
  plotBeats         PlotBeat[]
  chapterSummaries  ChapterSummary[]
  facts             ConsistencyFact[]
  generationJobs    GenerationJob[]
  agentRuns          AgentRun[]
  creativeDecisions  CreativeDecision[]
  novelSnapshots     NovelSnapshot[]
  storylineVersions  StorylineVersion[]
  volumePlans        VolumePlan[]
  volumePlanVersions VolumePlanVersion[]
  qualityReports     QualityReport[]
  storyMacroPlan     StoryMacroPlan?
  bookContract       BookContract?
  storyStateSnapshots StoryStateSnapshot[]
  canonicalStateVersions CanonicalStateVersion[]
  stateChangeProposals StateChangeProposal[]
  openConflicts      OpenConflict[]
  payoffLedgerItems  PayoffLedgerItem[]
  artifactSyncCheckpoints ChapterArtifactSyncCheckpoint[]
  storyPlans         StoryPlan[]
  replanRuns         ReplanRun[]
  auditReports       AuditReport[]
  workflowTasks      NovelWorkflowTask[]
  autoApprovalRecords AutoDirectorAutoApprovalRecord[]
  directorRuns       DirectorRun[]
  directorCommands   DirectorRunCommand[]
  directorEvents     DirectorEvent[]
  directorArtifacts  DirectorArtifact[]
  directorLlmUsageRecords DirectorLlmUsageRecord[]
  promptAddendums    PromptAddendum[]
  imageTasks         ImageGenerationTask[]
  imageAssets        ImageAsset[]
  sideEffectJobs     NovelSideEffectJob[]
  novelWorld         NovelWorld?
  factEntries        NovelFactEntry[]
  createdAt          DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([genreId])
  @@index([primaryStoryModeId])
  @@index([secondaryStoryModeId])
  @@index([worldId])
  @@index([writingMode])
  @@index([sourceNovelId])
  @@index([sourceKnowledgeDocumentId])
  @@index([continuationBookAnalysisId])
}

model PromptAddendum {
  id        String   @id @default(cuid())
  scope     String
  novelId   String?
  promptId  String
  title     String
  content   String
  enabled   Boolean  @default(true)
  novel     Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, promptId, enabled])
  @@index([novelId, promptId, enabled])
  @@index([updatedAt])
}

model CreativeDecision {
  id          String   @id @default(cuid())
  novelId     String
  chapterId   String?
  category    String
  content     String
  importance  String   @default("normal")
  expiresAt   Int?
  sourceType  String?
  sourceRefId String?
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([novelId, createdAt])
}

model NovelSnapshot {
  id           String   @id @default(cuid())
  novelId      String
  label        String?
  snapshotData String
  triggerType  String
  novel        Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([novelId, createdAt])
}

model Chapter {
  id              String                 @id @default(cuid())
  title           String
  content         String?                @default("")
  order           Int
  generationState ChapterGenerationState @default(planned)
  chapterStatus   ChapterStatus?         @default(unplanned)
  targetWordCount Int?
  conflictLevel   Int?
  revealLevel     Int?
  mustAvoid       String?
  taskSheet       String?
  sceneCards      String?
  repairHistory   String?
  qualityScore    Int?
  continuityScore Int?
  characterScore  Int?
  pacingScore     Int?
  riskFlags       String?
  hook            String?
  expectation     String?
  novelId         String
  novel           Novel                  @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterSummary  ChapterSummary?
  characterTimelines CharacterTimeline[]
  characterCandidates CharacterCandidate[] @relation("CharacterCandidateSourceChapter")
  characterFactionTracks CharacterFactionTrack[]
  characterRelationStages CharacterRelationStage[] @relation("CharacterRelationStageChapter")
  facts           ConsistencyFact[]
  qualityReports  QualityReport[]
  storyStateSnapshots StoryStateSnapshot[]
  canonicalStateVersions CanonicalStateVersion[]
  stateChangeProposals StateChangeProposal[]
  openConflicts      OpenConflict[]
  storyPlans      StoryPlan[]
  replanRuns      ReplanRun[]
  auditReports    AuditReport[]
  foreshadowSetupStates ForeshadowState[] @relation("ForeshadowSetupChapter")
  foreshadowPayoffStates ForeshadowState[] @relation("ForeshadowPayoffChapter")
  payoffLedgerLastTouchedItems PayoffLedgerItem[] @relation("PayoffLedgerLastTouchedChapter")
  payoffLedgerSetupItems PayoffLedgerItem[] @relation("PayoffLedgerSetupChapter")
  payoffLedgerPayoffItems PayoffLedgerItem[] @relation("PayoffLedgerPayoffChapter")
  introducedCharacterResources CharacterResourceLedgerItem[] @relation("CharacterResourceIntroducedChapter")
  lastTouchedCharacterResources CharacterResourceLedgerItem[] @relation("CharacterResourceLastTouchedChapter")
  characterResourceEvents CharacterResourceEvent[]
  artifactSyncCheckpoints ChapterArtifactSyncCheckpoint[]
  volumeChapterPlans VolumeChapterPlan[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([novelId, order])
}

model ChapterArtifactSyncCheckpoint {
  id           String   @id @default(cuid())
  novelId      String
  chapterId    String
  contentHash  String
  artifactType String
  syncMode     String
  status       String   @default("succeeded")
  sourceType   String?
  sourceStage  String?
  metadataJson String?
  novel        Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter      Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([novelId, chapterId, contentHash, artifactType, syncMode])
  @@index([novelId, chapterId, artifactType, updatedAt])
}

model Character {
  id              String   @id @default(cuid())
  name            String
  role            String
  gender          CharacterGender @default(unknown)
  castRole        String?
  storyFunction   String?
  relationToProtagonist String?
  personality     String?
  background      String?
  development     String?
  identityLabel   String?
  factionLabel    String?
  stanceLabel     String?
  powerLevel      String?
  realm           String?
  currentLocation String?
  availability    String?
  prohibitionsJson String @default("[]")
  outerGoal       String?
  innerNeed       String?
  fear            String?
  wound           String?
  misbelief       String?
  secret          String?
  moralLine       String?
  firstImpression String?
  appearance      String?
  physique        String?
  attireStyle     String?
  signatureDetail String?
  voiceTexture    String?
  presenceImpression String?
  arcStart        String?
  arcMidpoint     String?
  arcClimax       String?
  arcEnd          String?
  currentState    String?
  currentGoal     String?
  lastEvolvedAt   DateTime?
  novelId         String
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  baseCharacterId String?
  libraryLink     CharacterLibraryLink?
  timelines       CharacterTimeline[]
  matchedCandidates CharacterCandidate[] @relation("CharacterCandidateMatchedCharacter")
  volumeAssignments CharacterVolumeAssignment[]
  factionTracks CharacterFactionTrack[]
  outgoingRelationStages CharacterRelationStage[] @relation("CharacterRelationStageSource")
  incomingRelationStages CharacterRelationStage[] @relation("CharacterRelationStageTarget")
  stateEntries    CharacterState[]
  outgoingRelations RelationState[] @relation("RelationStateSource")
  incomingRelations RelationState[] @relation("RelationStateTarget")
  outgoingCharacterRelations CharacterRelation[] @relation("CharacterRelationSource")
  incomingCharacterRelations CharacterRelation[] @relation("CharacterRelationTarget")
  ownedResourceItems CharacterResourceLedgerItem[] @relation("CharacterResourceOwner")
  heldResourceItems CharacterResourceLedgerItem[] @relation("CharacterResourceHolder")
  actedResourceEvents CharacterResourceEvent[] @relation("CharacterResourceEventActor")
  fromResourceEvents CharacterResourceEvent[] @relation("CharacterResourceEventFromHolder")
  toResourceEvents CharacterResourceEvent[] @relation("CharacterResourceEventToHolder")
  syncProposals   CharacterSyncProposal[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([novelId])
  @@index([baseCharacterId])
}

model CharacterRelation {
  id                String   @id @default(cuid())
  novelId           String
  sourceCharacterId String
  targetCharacterId String
  surfaceRelation   String
  hiddenTension     String?
  conflictSource    String?
  secretAsymmetry   String?
  dynamicLabel      String?
  nextTurnPoint     String?
  trustScore        Int?
  conflictScore     Int?
  intimacyScore     Int?
  dependencyScore   Int?
  evidence          String?
  novel             Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  sourceCharacter   Character @relation("CharacterRelationSource", fields: [sourceCharacterId], references: [id], onDelete: Cascade)
  targetCharacter   Character @relation("CharacterRelationTarget", fields: [targetCharacterId], references: [id], onDelete: Cascade)
  stages            CharacterRelationStage[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([novelId, sourceCharacterId, targetCharacterId])
  @@index([novelId, updatedAt])
  @@index([sourceCharacterId])
  @@index([targetCharacterId])
}

model CharacterCastOption {
  id                String   @id @default(cuid())
  novelId           String
  title             String
  summary           String
  whyItWorks        String?
  recommendedReason String?
  status            String   @default("draft")
  sourceStoryInput  String?
  novel             Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  members           CharacterCastOptionMember[]
  relations         CharacterCastOptionRelation[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([novelId, updatedAt])
}

model CharacterCastOptionMember {
  id                    String   @id @default(cuid())
  optionId              String
  sortOrder             Int
  name                  String
  role                  String
  gender                CharacterGender @default(unknown)
  castRole              String
  relationToProtagonist String?
  storyFunction         String
  shortDescription      String?
  personality           String?
  background            String?
  development           String?
  identityLabel         String?
  factionLabel          String?
  stanceLabel           String?
  powerLevel            String?
  realm                 String?
  currentLocation       String?
  availability          String?
  prohibitionsJson      String @default("[]")
  outerGoal             String?
  innerNeed             String?
  fear                  String?
  wound                 String?
  misbelief             String?
  secret                String?
  moralLine             String?
  firstImpression       String?
  option                CharacterCastOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([optionId, sortOrder])
}

model CharacterCastOptionRelation {
  id              String   @id @default(cuid())
  optionId        String
  sortOrder       Int
  sourceName      String
  targetName      String
  surfaceRelation String
  hiddenTension   String?
  conflictSource  String?
  secretAsymmetry String?
  dynamicLabel    String?
  nextTurnPoint   String?
  option          CharacterCastOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([optionId, sortOrder])
}

model CharacterTimeline {
  id          String    @id @default(cuid())
  novelId     String
  characterId String
  chapterId   String?
  chapterOrder Int?
  title       String
  content     String
  source      String    @default("auto")
  novel       Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  chapter     Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([novelId, characterId])
  @@index([characterId, chapterOrder])
  @@index([chapterId])
}

model CharacterCandidate {
  id                String     @id @default(cuid())
  novelId           String
  sourceChapterId   String?
  proposedName      String
  proposedRole      String?
  summary           String?
  evidenceJson      String?
  matchedCharacterId String?
  status            String     @default("pending")
  confidence        Float?
  novel             Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade)
  sourceChapter     Chapter?   @relation("CharacterCandidateSourceChapter", fields: [sourceChapterId], references: [id], onDelete: SetNull)
  matchedCharacter  Character? @relation("CharacterCandidateMatchedCharacter", fields: [matchedCharacterId], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([novelId, status, updatedAt])
  @@index([sourceChapterId])
  @@index([matchedCharacterId])
}

model CharacterVolumeAssignment {
  id                        String    @id @default(cuid())
  novelId                   String
  characterId               String
  volumeId                  String
  roleLabel                 String?
  responsibility            String
  appearanceExpectation     String?
  plannedChapterOrdersJson  String?
  isCore                    Boolean   @default(false)
  absenceWarningThreshold   Int       @default(3)
  absenceHighRiskThreshold  Int       @default(5)
  novel                     Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  character                 Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  volume                    VolumePlan @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@unique([characterId, volumeId])
  @@index([novelId, volumeId, isCore])
  @@index([volumeId, characterId])
}

model CharacterFactionTrack {
  id           String    @id @default(cuid())
  novelId      String
  characterId  String
  volumeId      String?
  chapterId     String?
  chapterOrder  Int?
  factionLabel  String
  stanceLabel   String?
  summary       String?
  sourceType    String
  confidence    Float?
  novel         Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  volume        VolumePlan? @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  chapter       Chapter?   @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([novelId, characterId, createdAt])
  @@index([volumeId, characterId, createdAt])
  @@index([chapterId, createdAt])
}

model CharacterRelationStage {
  id                 String    @id @default(cuid())
  novelId            String
  relationId         String?
  sourceCharacterId  String
  targetCharacterId  String
  volumeId           String?
  chapterId          String?
  chapterOrder       Int?
  stageLabel         String
  stageSummary       String
  nextTurnPoint      String?
  sourceType         String
  confidence         Float?
  isCurrent          Boolean   @default(true)
  novel              Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  relation           CharacterRelation? @relation(fields: [relationId], references: [id], onDelete: SetNull)
  sourceCharacter    Character @relation("CharacterRelationStageSource", fields: [sourceCharacterId], references: [id], onDelete: Cascade)
  targetCharacter    Character @relation("CharacterRelationStageTarget", fields: [targetCharacterId], references: [id], onDelete: Cascade)
  volume             VolumePlan? @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  chapter            Chapter?   @relation("CharacterRelationStageChapter", fields: [chapterId], references: [id], onDelete: SetNull)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([novelId, isCurrent, updatedAt])
  @@index([sourceCharacterId, targetCharacterId, isCurrent])
  @@index([relationId])
  @@index([chapterId])
}

model BaseCharacter {
  id          String   @id @default(cuid())
  name        String
  role        String
  personality String
  background  String
  development String
  appearance  String?
  weaknesses  String?
  interests   String?
  keyEvents   String?
  tags        String   @default("")
  category    String
  revisions   BaseCharacterRevision[]
  libraryLinks CharacterLibraryLink[]
  syncProposals CharacterSyncProposal[]
  imageTasks  ImageGenerationTask[]
  imageAssets ImageAsset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BaseCharacterRevision {
  id              String   @id @default(cuid())
  baseCharacterId String
  version         Int
  snapshotJson    String
  changeSummary   String?
  sourceType      String   @default("manual")
  sourceRefId     String?
  baseCharacter   BaseCharacter @relation(fields: [baseCharacterId], references: [id], onDelete: Cascade)
  libraryLinks    CharacterLibraryLink[]
  syncProposals   CharacterSyncProposal[]
  createdAt       DateTime @default(now())

  @@unique([baseCharacterId, version])
  @@index([baseCharacterId, createdAt])
}

model CharacterLibraryLink {
  id                String   @id @default(cuid())
  novelId           String
  characterId       String   @unique
  baseCharacterId   String
  baseRevisionId    String?
  syncPolicy        String   @default("manual_review")
  linkStatus        String   @default("linked")
  localOverridesJson String?
  lastSyncedAt      DateTime?
  novel             Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  baseCharacter     BaseCharacter @relation(fields: [baseCharacterId], references: [id], onDelete: Cascade)
  baseRevision      BaseCharacterRevision? @relation(fields: [baseRevisionId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([novelId, linkStatus, updatedAt])
  @@index([baseCharacterId, linkStatus, updatedAt])
  @@index([baseRevisionId])
}

model CharacterSyncProposal {
  id                String   @id @default(cuid())
  novelId           String?
  characterId       String?
  baseCharacterId   String?
  baseRevisionId    String?
  direction         String
  status            String   @default("pending_review")
  confidence        Float?
  summary           String
  payloadJson       String
  safeUpdatesJson   String?
  novelOnlyUpdatesJson String?
  riskyUpdatesJson  String?
  recommendedAction String?
  sourceType        String   @default("manual")
  sourceRefId       String?
  novel             Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  character         Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  baseCharacter     BaseCharacter? @relation(fields: [baseCharacterId], references: [id], onDelete: Cascade)
  baseRevision      BaseCharacterRevision? @relation(fields: [baseRevisionId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([novelId, status, updatedAt])
  @@index([characterId, status, updatedAt])
  @@index([baseCharacterId, status, updatedAt])
  @@index([baseRevisionId])
}

model ImageGenerationTask {
  id              String            @id @default(cuid())
  sceneType       ImageSceneType    @default(character)
  baseCharacterId String?
  novelId         String?
  provider        String
  model           String
  prompt          String
  negativePrompt  String?
  stylePreset     String?
