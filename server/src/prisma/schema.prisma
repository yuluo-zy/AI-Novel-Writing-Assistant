  novel                Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter              Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  parent               StoryPlan? @relation("StoryPlanHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children             StoryPlan[] @relation("StoryPlanHierarchy")
  sourceStateSnapshot  StoryStateSnapshot? @relation(fields: [sourceStateSnapshotId], references: [id], onDelete: SetNull)
  scenes               ChapterPlanScene[]
  replanRuns           ReplanRun[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([novelId, level, createdAt])
  @@index([novelId, level, externalRef])
  @@index([novelId, level, chapterId])
  @@index([chapterId, createdAt])
  @@index([externalRef])
  @@index([sourceStateSnapshotId])
}

model ChapterPlanScene {
  id          String   @id @default(cuid())
  planId       String
  sortOrder    Int
  title        String
  objective    String?
  conflict     String?
  reveal       String?
  emotionBeat  String?
  plan         StoryPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([planId, sortOrder])
}

model ReplanRun {
  id           String   @id @default(cuid())
  novelId      String
  chapterId    String?
  sourcePlanId String?
  triggerType  String
  reason       String
  outputSummary String?
  novel        Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter      Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  sourcePlan   StoryPlan? @relation(fields: [sourcePlanId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([novelId, createdAt])
  @@index([chapterId, createdAt])
}

model AuditReport {
  id             String   @id @default(cuid())
  novelId        String
  chapterId      String
  auditType      AuditType
  overallScore   Int?
  summary        String?
  legacyScoreJson String?
  novel          Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter        Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  issues         AuditIssue[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([novelId, chapterId, auditType, createdAt])
  @@index([chapterId, createdAt])
}

model AuditIssue {
  id            String   @id @default(cuid())
  reportId      String
  auditType     AuditType
  severity      String
  code          String
  description   String
  evidence      String
  fixSuggestion String
  status        AuditIssueStatus @default(open)
  report        AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([reportId, status])
  @@index([auditType, severity])
}

model KnowledgeDocument {
  id                     String                   @id @default(cuid())
  title                  String
  fileName               String
  status                 KnowledgeDocumentStatus  @default(enabled)
  activeVersionId        String?
  activeVersionNumber    Int                      @default(0)
  latestIndexStatus      KnowledgeIndexStatus     @default(idle)
  lastIndexedAt          DateTime?
  activeVersion          KnowledgeDocumentVersion? @relation("KnowledgeDocumentActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  versions               KnowledgeDocumentVersion[] @relation("KnowledgeDocumentVersions")
  bindings               KnowledgeBinding[]
  bookAnalyses           BookAnalysis[]
  publishedFromAnalyses  BookAnalysis[]           @relation("BookAnalysisPublishedDocument")
  continuationNovels     Novel[]                  @relation("NovelKnowledgeContinuation")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([status, updatedAt])
  @@index([title])
}

model KnowledgeDocumentVersion {
  id                 String               @id @default(cuid())
  documentId         String
  versionNumber      Int
  content            String
  contentHash        String
  charCount          Int
  document           KnowledgeDocument    @relation("KnowledgeDocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  activeForDocuments KnowledgeDocument[]  @relation("KnowledgeDocumentActiveVersion")
  bookAnalyses       BookAnalysis[]
  sourceCaches       BookAnalysisSourceCache[]
  createdAt          DateTime             @default(now())

  @@unique([documentId, versionNumber])
  @@index([documentId, createdAt])
  @@index([contentHash])
}

model KnowledgeBinding {
  id         String                     @id @default(cuid())
  targetType KnowledgeBindingTargetType
  targetId   String
  documentId String
  document   KnowledgeDocument          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime                   @default(now())

  @@unique([targetType, targetId, documentId])
  @@index([targetType, targetId])
  @@index([documentId])
}

model BookAnalysis {
  id                          String             @id @default(cuid())
  documentId                  String
  documentVersionId           String
  title                       String
  status                      BookAnalysisStatus @default(queued)
  summary                     String?
  provider                    String?
  model                       String?
  temperature                 Float?
  maxTokens                   Int?
  progress                    Float              @default(0)
  pendingManualRecovery       Boolean            @default(false)
  heartbeatAt                 DateTime?
  currentStage                String?
  currentItemKey              String?
  currentItemLabel            String?
  cancelRequestedAt           DateTime?
  attemptCount                Int                @default(0)
  maxAttempts                 Int                @default(1)
  lastError                   String?
  lastRunAt                   DateTime?
  publishedDocumentId         String?
  document                    KnowledgeDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion             KnowledgeDocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: NoAction)
  publishedDocument           KnowledgeDocument?  @relation("BookAnalysisPublishedDocument", fields: [publishedDocumentId], references: [id], onDelete: SetNull)
  continuationNovels          Novel[]             @relation("NovelContinuationBookAnalysis")
  sections                    BookAnalysisSection[]
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  @@index([documentId, status])
  @@index([documentVersionId])
  @@index([status, updatedAt])
}

model BookAnalysisSourceCache {
  id                String                   @id @default(cuid())
  documentVersionId String
  provider          String
  model             String
  temperature       Float
  notesMaxTokens    Int
  segmentVersion    Int                      @default(1)
  segmentCount      Int
  notesJson         String
  documentVersion   KnowledgeDocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([documentVersionId, provider, model, temperature, notesMaxTokens, segmentVersion])
  @@index([documentVersionId, updatedAt])
}

model BookAnalysisSection {
  id                 String                    @id @default(cuid())
  analysisId         String
  sectionKey         String
  title              String
  status             BookAnalysisSectionStatus @default(idle)
  aiContent          String?
  editedContent      String?
  notes              String?
  structuredDataJson String?
  evidenceJson       String?
  frozen             Boolean                   @default(false)
  sortOrder          Int
  analysis           BookAnalysis              @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  updatedAt          DateTime                  @updatedAt

  @@unique([analysisId, sectionKey])
  @@index([analysisId, sortOrder])
}

model KnowledgeChunk {
  id            String       @id @default(cuid())
  tenantId      String       @default("default")
  ownerType     RagOwnerType
  ownerId       String
  novelId       String?
  worldId       String?
  title         String?
  chunkText     String
  chunkHash     String
  chunkOrder    Int
  tokenEstimate Int          @default(0)
  language      String       @default("zh")
  metadataJson  String?
  embedProvider String
  embedModel    String
  embedVersion  Int          @default(1)
  indexedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId, ownerType, ownerId])
  @@index([tenantId, novelId])
  @@index([tenantId, worldId])
  @@index([chunkHash])
}

model RagIndexJob {
  id          String       @id @default(cuid())
  tenantId    String       @default("default")
  jobType     RagJobType
  ownerType   RagOwnerType
  ownerId     String
  status      RagJobStatus @default(queued)
  attempts    Int          @default(0)
  maxAttempts Int          @default(5)
  runAfter    DateTime     @default(now())
  payloadJson String?
  lastError   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, runAfter])
  @@index([tenantId, ownerType, ownerId])
}

model NovelSideEffectJob {
  id               String    @id @default(cuid())
  novelId          String?
  jobType          String
  status           String    @default("pending")
  idempotencyKey   String    @unique
  payloadVersion   Int       @default(1)
  payloadJson      String
  attempts         Int       @default(0)
  maxAttempts      Int       @default(5)
  runAfter         DateTime  @default(now())
  leaseOwner       String?
  leaseExpiresAt   DateTime?
  lastError        String?
  finishedAt       DateTime?
  novel            Novel?    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, runAfter])
  @@index([novelId, status, updatedAt])
  @@index([leaseOwner, leaseExpiresAt])
  @@index([jobType, status, runAfter])
}

model TaskCenterArchive {
  id         String   @id @default(cuid())
  taskKind   String
  taskId     String
  archivedAt DateTime @default(now())

  @@unique([taskKind, taskId])
  @@index([taskKind, archivedAt])
}

model StoryTimelineEvent {
  id                   String   @id @default(cuid())
  novelId              String
  chapterId            String?
  chapterIndex         Int?
  eventOrder           Int
  storyDayIndex        Int?
  storyTimeLabel       String?
  title                String
  summary              String
  type                 String
  status               String
  visibility           String
  source               String
  participantIdsJson   String   @default("[]")
  locationId           String?
  factionIdsJson       String   @default("[]")
  prerequisiteIdsJson  String   @default("[]")
  consequenceIdsJson   String   @default("[]")
  stateChangesJson     String   @default("[]")
  eventKey             String?
  confidence           Float    @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([novelId, chapterIndex])
  @@index([novelId, eventOrder])
  @@index([novelId, status])
  @@index([novelId, eventKey])
}

model ChapterTimeAnchor {
  id                   String   @id @default(cuid())
  novelId              String
  chapterId            String
  chapterIndex         Int
  storyDayIndex        Int?
  timeLabel            String
  startsAfterIdsJson   String   @default("[]")
  plannedEventIdsJson  String   @default("[]")
  endedWithIdsJson     String   @default("[]")
  previousHookIdsJson  String   @default("[]")
  nextHookIdsJson      String   @default("[]")
  forbiddenEventIdsJson String  @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([novelId, chapterId])
  @@index([novelId, chapterIndex])
}

model TimelineHook {
  id                            String   @id @default(cuid())
  novelId                       String
  createdInChapterId            String
  createdInChapterIndex         Int
  expectedResolveByChapterIndex Int?
  resolveMode                   String   @default("long_arc")
  blocking                      Boolean  @default(false)
  resolvedInChapterId           String?
  resolvedInChapterIndex        Int?
  title                         String
  description                   String
  status                        String
  priority                      String
  relatedEventIdsJson           String   @default("[]")
  participantIdsJson            String   @default("[]")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([novelId, status])
  @@index([novelId, resolveMode, blocking])
  @@index([novelId, createdInChapterIndex])
  @@index([novelId, expectedResolveByChapterIndex])
}

model TimelineConstraint {
  id                       String   @id @default(cuid())
  novelId                  String
  chapterId                String?
  chapterIndex             Int?
  type                     String
  severity                 String
  description              String
  relatedEventIdsJson      String   @default("[]")
  relatedHookIdsJson       String   @default("[]")
  relatedCharacterIdsJson  String   @default("[]")
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([novelId, chapterIndex])
  @@index([novelId, active])
}

model TimelineCheckReport {
  id           String   @id @default(cuid())
  novelId      String
  chapterId    String
  chapterIndex Int
  status       String
  score        Float
  issuesJson   String   @default("[]")
  createdAt    DateTime @default(now())

  @@index([novelId, chapterIndex])
  @@index([novelId, status])
}

// 事实账本：记录小说中已发生的不可逆事实，用于防止后续章节重复或矛盾
model NovelFactEntry {
  id           String   @id @default(cuid())
  novelId      String
  // 事实发生在第几章（用于排序和范围查询）
  chapterOrder Int
  // 一两句话描述，例如"陈建国已在第7章取得个体户执照"
  text         String
  // completed=过程性目标已完成；revealed=信息已揭示；state_changed=不可逆状态变化
  category     String   @default("completed")
  // auto=系统自动写入；manual=Agent工具手动写入
  source       String   @default("auto")
  novel        Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([novelId, chapterOrder])
  @@index([novelId, category])
}
